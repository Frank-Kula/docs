{
  "openapi": "3.0.1",
  "info": {
    "title": "🦄 多模块&多分支&Github备份",
    "description": "Example API to demonstrate schema linking issues with scheduled data source import",
    "version": "1.0.0"
  },
  "tags": [],
  "paths": {
    "/api/v1/api-keys": {
      "post": {
        "summary": "Generate an API Key",
        "deprecated": false,
        "description": "Create a new API Key",
        "operationId": "generateApiKey",
        "tags": [],
        "parameters": [],
        "requestBody": {
          "content": {
            "application/json": {
              "schema": {
                "$ref": "#/components/schemas/AddApiKeyRequest"
              }
            }
          },
          "required": true
        },
        "responses": {
          "200": {
            "description": "API Key created successfully",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/ApiKeyResponse"
                }
              }
            },
            "headers": {}
          },
          "400": {
            "description": "Bad Request",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "headers": {}
          },
          "401": {
            "description": "Unauthorized",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "headers": {}
          },
          "403": {
            "description": "Forbidden",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "headers": {}
          },
          "404": {
            "description": "Record Not Found",
            "content": {
              "application/json": {
                "schema": {
                  "$ref": "#/components/schemas/Error"
                }
              }
            },
            "headers": {}
          }
        },
        "security": []
      }
    }
  },
  "components": {
    "schemas": {
      "AddApiKeyRequest": {
        "type": "object",
        "description": "Request body for creating an API Key",
        "required": [
          "subscriptionId",
          "name",
          "roles"
        ],
        "properties": {
          "subscriptionId": {
            "type": "string",
            "format": "uuid",
            "description": "Subscription ID"
          },
          "primarySubscriptionId": {
            "type": "string",
            "description": "Primary subscription ID",
            "nullable": true
          },
          "name": {
            "type": "string",
            "description": "API Key name",
            "minLength": 1,
            "maxLength": 100
          },
          "roles": {
            "type": "array",
            "description": "List of roles",
            "items": {
              "type": "string"
            },
            "minItems": 1
          },
          "claims": {
            "type": "array",
            "description": "List of claims",
            "items": {
              "type": "string"
            }
          }
        }
      },
      "ApiKeyResponse": {
        "type": "object",
        "description": "API Key response",
        "required": [
          "id",
          "name",
          "key",
          "createdAt"
        ],
        "properties": {
          "id": {
            "type": "string",
            "format": "uuid",
            "description": "API Key ID"
          },
          "name": {
            "type": "string",
            "description": "API Key name"
          },
          "key": {
            "type": "string",
            "description": "API Key value",
            "readOnly": true
          },
          "subscriptionId": {
            "type": "string",
            "format": "uuid",
            "description": "Subscription ID"
          },
          "roles": {
            "type": "array",
            "description": "List of roles",
            "items": {
              "type": "string"
            }
          },
          "createdAt": {
            "type": "string",
            "format": "date-time",
            "description": "Creation timestamp"
          },
          "expiresAt": {
            "type": "string",
            "format": "date-time",
            "description": "Expiration timestamp",
            "nullable": true
          }
        }
      },
      "Error": {
        "type": "object",
        "description": "Error response",
        "required": [
          "code",
          "message"
        ],
        "properties": {
          "code": {
            "type": "integer",
            "description": "Error code"
          },
          "message": {
            "type": "string",
            "description": "Error message"
          },
          "details": {
            "type": "object",
            "description": "Additional error details",
            "additionalProperties": true,
            "properties": {}
          }
        }
      }
    },
    "responses": {},
    "securitySchemes": {}
  },
  "servers": [],
  "security": []
}